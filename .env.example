# =============================================================================
# IPSHub - Environment Variables
# Copy this file to .env and fill in your values before native macOS startup.
# =============================================================================

# ----- Runtime ---------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info

# ----- App -------------------------------------------------------------------
# Public URL exposed by this macOS host (IP:port or domain).
# Clash/Loon subscription links will embed this base URL.
# Examples:
#   Plain HTTP via LAN IP  -> http://192.168.1.100:8080
#   HTTPS reverse proxy    -> https://sub.example.com
APP_BASE_URL=http://127.0.0.1:8080

# REQUIRED: A 32-byte hex secret used for session signing.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=please-change-this-secret-in-production

# ----- Cookie ----------------------------------------------------------------
# Set to 'true' ONLY when the app is accessed over HTTPS.
# Set to 'false' for plain HTTP on a LAN or localhost.
COOKIE_SECURE=false

# ----- Admin Credentials (used only on first startup) -----------------------
ADMIN_USERNAME=admin
# IMPORTANT: Change before first run!
ADMIN_PASSWORD=please-change-this-password

# ----- Database --------------------------------------------------------------
# Native macOS SQLite path, relative to the repository root.
DB_PATH=./data/ipshub.db

# ----- Server ---------------------------------------------------------------
# Native backend port. The backend also serves built frontend assets in prod.
SERVER_PORT=8080

# ----- Docker compatibility --------------------------------------------------
# Only used by deploy/docker/docker-compose.yml.
WEB_PORT=8088
