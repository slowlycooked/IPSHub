# =============================================================================
# IPSHub – Environment Variables
# Copy this file to .env and fill in your values before running docker compose.
# =============================================================================

# ----- Runtime ---------------------------------------------------------------
NODE_ENV=production
LOG_LEVEL=info

# ----- App -------------------------------------------------------------------
# Public URL exposed by the NAS (IP:port or domain).
# Clash/Loon subscription links will embed this base URL.
# Examples:
#   Plain HTTP via NAS IP  → http://192.168.1.100:8088
#   NAS with custom domain → https://sub.example.com
APP_BASE_URL=http://192.168.1.100:8088

# REQUIRED: A 32-byte hex secret used for session signing.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=please-change-this-secret-in-production

# ----- Cookie ----------------------------------------------------------------
# Set to 'true' ONLY when the NAS is accessed over HTTPS (reverse proxy + TLS).
# Set to 'false' for plain HTTP (NAS internal IP access, no TLS).
COOKIE_SECURE=false

# ----- Admin Credentials (used only on first startup) -----------------------
ADMIN_USERNAME=admin
# IMPORTANT: Change before first run!
ADMIN_PASSWORD=please-change-this-password

# ----- Web Port (host-side) -------------------------------------------------
# The NAS host port that maps to the nginx container's port 80.
# Access the app via:  http://NAS_IP:WEB_PORT
WEB_PORT=8088

# ----- Database --------------------------------------------------------------
# Absolute path inside the backend container.
# The host volume mount in docker-compose keeps the actual file in ./data/.
DB_PATH=/app/data/ipshub.db

# ----- Server (internal) -----------------------------------------------------
# Internal port of the backend container. Change only if 8080 conflicts.
SERVER_PORT=8080
