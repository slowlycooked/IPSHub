# Server Configuration
NODE_ENV=development
LOG_LEVEL=debug

# App Configuration
APP_BASE_URL=http://localhost:8088
# IMPORTANT: Change this to a secure random string in production!
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SECRET=please-change-this-secret-in-production

# Cookie Configuration
# Set to 'true' only if using HTTPS, or when running behind a reverse proxy with HTTPS
# Set to 'false' for HTTP-only environments (e.g., accessing via NAS internal IP)
COOKIE_SECURE=false

# Admin Credentials (for initial setup)
ADMIN_USERNAME=admin
# IMPORTANT: Change this password in production!
ADMIN_PASSWORD=please-change-this-password

# Server Port (internal, only change if port 8080 is not available)
SERVER_PORT=8080
