{
  "name": "@ipshub/server",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx ./src/index.ts",
    "build": "tsc && tsc-alias --resolve-full-paths --resolve-full-extension .js",
    "start": "node dist/index.js",
    "lint": "eslint src --ext ts --max-warnings 0",
    "format": "prettier --write src",
    "test": "vitest"
  },
  "dependencies": {
    "fastify": "^4.25.2",
    "@fastify/cors": "^8.4.2",
    "@fastify/cookie": "^9.3.1",
    "@fastify/static": "^6.12.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^16.6.1",
    "zod": "^3.22.4",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "node-cron": "^3.0.3",
    "yaml": "^2.4.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "tsc-alias": "^1.8.8",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
